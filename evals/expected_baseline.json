{
  "meta": {
    "dataset": "CAISO demand",
    "region": "CAISO",
    "time_range": "2026-03-23 to 2026-03-30",
    "version": "v1-demand-only"
  },
  "cases": [
    {
      "id": "Q1",
      "question": "Summarize CAISO demand trends across the full week.",
      "expect": {
        "must_include_fields": ["region", "time_range", "daily_metrics", "summary", "notes"],
        "summary_contains": ["Highest peak", "Lowest minimum", "Average daily demand"]
      }
    },
    {
      "id": "Q2",
      "question": "Which day had the highest peak demand, and what time did it occur?",
      "expect": {
        "highest_peak_date": "2026-03-24",
        "highest_peak_demand": 30073.0,
        "time_of_peak_on_day": "18:50"
      }
    },
    {
      "id": "Q3",
      "question": "Which day had the lowest minimum demand, and what time did it occur?",
      "expect": {
        "lowest_min_date": "2026-03-29",
        "lowest_min_demand": 14422.0,
        "time_of_min_on_day": "12:00"
      }
    },
    {
      "id": "Q4",
      "question": "What was the average daily demand across all analyzed days?",
      "expect": {
        "avg_daily_demand_approx": 22578.43,
        "tolerance": 0.5
      }
    },
    {
      "id": "Q5",
      "question": "For each day, list notable spike intervals.",
      "expect": {
        "days_analyzed": 8,
        "min_spikes_per_day": 1
      }
    },
    {
      "id": "Q6",
      "question": "Compare weekday versus weekend demand behavior in this window.",
      "expect": {
        "qualitative": true,
        "requires_weekday_weekend_comparison": true
      }
    },
    {
      "id": "Q7",
      "question": "Which day appears most volatile based on spread between min and peak demand?",
      "expect": {
        "qualitative": true,
        "requires_spread_reasoning": true
      }
    },
    {
      "id": "Q8",
      "question": "Identify the top three days by peak demand and explain the ranking.",
      "expect": {
        "top3_peak_dates_order": ["2026-03-24", "2026-03-26", "2026-03-23"]
      }
    },
    {
      "id": "Q9",
      "question": "Provide a concise operator briefing with top risks and monitoring notes.",
      "expect": {
        "qualitative": true,
        "requires_actionable_notes": true
      }
    },
    {
      "id": "Q10",
      "question": "What limitations should we note before using this output operationally?",
      "expect": {
        "must_mention": ["demand-only", "no price analysis"]
      }
    }
  ]
}
